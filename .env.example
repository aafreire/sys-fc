# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sys_fc_dev

# ── Phoenix / Ecto ──────────────────────────────────────────
# Usado em produção (runtime.exs); em dev o DB_HOST é suficiente
# Porta 5433 no host para evitar conflito com PostgreSQL local (que usa 5432)
DATABASE_URL=ecto://postgres:postgres@db/sys_fc_dev

# Hostname do banco de dados (nome do serviço no docker-compose)
DB_HOST=db

# Chave secreta — gere com: mix phx.gen.secret
SECRET_KEY_BASE=COLOQUE_AQUI_UMA_CHAVE_GERADA

# ── Endpoint ────────────────────────────────────────────────
PHX_HOST=localhost
PORT=4000

# Habilita o servidor web em releases (não necessário em dev com mix phx.server)
# PHX_SERVER=true

# ── JWT ─────────────────────────────────────────────────────
# Chave secreta para assinar tokens JWT (mínimo 32 chars)
JWT_SECRET=COLOQUE_AQUI_UMA_CHAVE_SECRETA_JWT_FORTE
# Expiração do token em segundos (padrão: 7 dias = 604800)
JWT_EXPIRY_SECONDS=604800

# ── CORS ────────────────────────────────────────────────────
# Origins permitidas (separar por vírgula se necessário)
CORS_ORIGINS=http://localhost:5173
